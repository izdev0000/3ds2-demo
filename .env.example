# docker compose 用の環境変数。ローカル運用ではこのファイルを `.env` にコピーして利用する。
# Laravel 自体の .env は backend-laravel/.env 側を参照する（compose とは別管理）。

# どの backend を起動するか。現状は laravel のみ実装されている。
COMPOSE_PROFILES=laravel

# ホスト側に公開するポート
FRONTEND_PORT=5173
BACKEND_PORT=8000
MYSQL_PORT=3306

# MySQL コンテナの初期化に使う値（backend-laravel/.env の DB_* と一致させる）
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=threeds2_demo
MYSQL_USER=laravel
MYSQL_PASSWORD=laravel

# Vite から見える backend のオリジン（ブラウザ → ホスト経由でアクセス）
VITE_BACKEND_ORIGIN=http://localhost:8000

# Stripe TEST 環境の secret key（sk_test_...）。stripe-cli の listen 認証に利用する。
# Dashboard > Developers > API keys から取得。本番 key は絶対に置かない。
STRIPE_API_KEY=
